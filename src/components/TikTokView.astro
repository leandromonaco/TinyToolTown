---
// Shorts-style viewer for TinyToolTown
import { getGitHubRepo } from '../lib/github';

interface Props {
  tools: any[];
}

const { tools } = Astro.props;

// Serialize only the fields needed to build each panel client-side.
// Replace < with \u003c to prevent </script> injection in the JSON data island.
const shortsToolsData = tools.map((tool) => ({
  slug: tool.id.replace(/\.md$/, ''),
  name: tool.data.name,
  tagline: tool.data.tagline,
  author: tool.data.author,
  authorGithub: tool.data.author_github,
  thumbnail: tool.data.thumbnail ?? null,
  githubUrl: tool.data.github_url,
  repo: getGitHubRepo(tool.data.github_url),
  tags: tool.data.tags.slice(0, 3),
}));
const shortsToolsJson = JSON.stringify(shortsToolsData).replace(/</g, '\\u003c');
---

<div id="shorts-viewer" class="viewer-hidden" role="dialog" aria-label="Tool shorts viewer" aria-modal="true">
  <button id="exit-shorts" class="exit-control" aria-label="Exit">✕</button>
  <div class="viewer-track"></div>
</div>

{/* Tool data island — consumed by buildPanels() when Shorts is first opened */}
<script type="application/json" id="shorts-tools-data" set:html={shortsToolsJson} />

<template id="shorts-panel-tpl">
  <section class="tool-panel">
    <div class="panel-bg">
      <img class="bg-image" src="" alt="" />
      <div class="bg-gradient"></div>
      <div class="bg-dim"></div>
    </div>
    <div class="panel-content">
      <div class="content-wrapper">
        <div class="tool-thumbnail">
          <div class="thumb-placeholder">&#x1F527;</div>
        </div>
        <h2 class="tool-heading"></h2>
        <p class="tool-description"></p>
        <div class="creator-info">
          <img class="creator-avatar" src="" alt="" width="28" height="28" />
          <span class="creator-handle"></span>
        </div>
        <div class="metadata-tags"></div>
        <a href="" class="navigate-link">View Full Details &#x2192;</a>
      </div>
    </div>
    <aside class="panel-actions">
      <button class="panel-action favorite-action" aria-label="Favorite">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /> </svg><span class="action-text">Like</span>
      </button>
      <button class="panel-action distribute-action" aria-label="Share">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <circle cx="18" cy="5" r="3" /> <circle cx="6" cy="12" r="3" /> <circle cx="18" cy="19" r="3" /> <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /> <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" /> </svg><span class="action-text">Share</span>
      </button>
      <a class="panel-action star-action" href="" target="_blank" rel="noopener noreferrer" aria-label="Star on GitHub">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"> <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /> </svg><span class="action-text star-count-text">Star</span>
      </a>
      <a class="panel-action repository-action" href="" target="_blank" rel="noopener noreferrer" aria-label="GitHub Repository">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"> <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/> </svg><span class="action-text">Code</span>
      </a>
    </aside>
    <div class="panel-counter"></div>
  </section>
</template>

<script>
  import { FAVORITES_CHANGED_EVENT, confirmFavoriteRemoval, isFavorited, toggleFavorite as toggleToolFavorite } from '../lib/favorites';

  const SWIPE_MIN = 60;
  const HUE_OFFSET_PRIMARY = 37;
  const HUE_OFFSET_SECONDARY = 53;

  let viewerState = { pos: 0, active: false, drag0: 0, dragging: false };
  let frameInit = false;
  let previousFocus: HTMLElement | null = null;

  // Build panel nodes from JSON data island by cloning the <template>.
  // Invoked on first Shorts open — keeps initial HTML payload small.
  function buildPanels() {
    const track = document.querySelector<HTMLElement>('.viewer-track');
    if (!track || track.children.length > 0) return;
    const tpl = document.getElementById('shorts-panel-tpl') as HTMLTemplateElement | null;
    const src = document.getElementById('shorts-tools-data');
    if (!tpl || !src) return;

    type ShortsToolEntry = {
      slug: string; name: string; tagline: string;
      author: string; authorGithub: string;
      thumbnail: string | null; githubUrl: string;
      repo: string | null; tags: string[];
    };
    let items: ShortsToolEntry[];
    try { items = JSON.parse(src.textContent || '[]'); } catch { return; }

    const total = items.length;
    const frag = document.createDocumentFragment();

    items.forEach((t, i) => {
      const node = document.importNode(tpl.content, true);
      const sec = node.querySelector('section')!;
      sec.dataset.position = String(i);

      const bgImg  = sec.querySelector<HTMLImageElement>('.bg-image')!;
      const bgGrad = sec.querySelector<HTMLElement>('.bg-gradient')!;
      if (t.thumbnail) {
        bgImg.src = t.thumbnail;
        bgGrad.remove();
      } else {
        bgImg.remove();
        bgGrad.style.background =
          `linear-gradient(135deg,hsl(${i * HUE_OFFSET_PRIMARY},70%,50%),hsl(${i * HUE_OFFSET_SECONDARY},60%,40%))`;
      }

      const thumb = sec.querySelector<HTMLElement>('.tool-thumbnail')!;
      if (t.thumbnail) thumb.remove();

      sec.querySelector('.tool-heading')!.textContent = t.name;
      sec.querySelector('.tool-description')!.textContent = t.tagline;

      const av = sec.querySelector<HTMLImageElement>('.creator-avatar')!;
      av.src = `https://avatars.githubusercontent.com/${t.authorGithub}?s=32`;
      av.alt = t.author;
      sec.querySelector('.creator-handle')!.textContent = `@${t.author}`;

      const tagsEl = sec.querySelector('.metadata-tags')!;
      t.tags.forEach(tag => {
        const sp = document.createElement('span');
        sp.className = 'metadata-tag';
        sp.textContent = tag;
        tagsEl.appendChild(sp);
      });

      sec.querySelector<HTMLAnchorElement>('.navigate-link')!.href = `/tools/${t.slug}/`;

      const favBtn = sec.querySelector<HTMLElement>('.favorite-action')!;
      favBtn.dataset.tool = t.slug;
      favBtn.addEventListener('click', toggleFavorite);

      const shrBtn = sec.querySelector<HTMLElement>('.distribute-action')!;
      shrBtn.dataset.toolTitle = t.name;
      shrBtn.addEventListener('click', sharePanel);

      const starA = sec.querySelector<HTMLAnchorElement>('.star-action')!;
      if (t.repo) {
        starA.href = t.githubUrl;
        starA.dataset.repo = t.repo;
      } else {
        starA.remove();
      }

      sec.querySelector<HTMLAnchorElement>('.repository-action')!.href = t.githubUrl;

      sec.querySelector('.panel-counter')!.textContent = `🔀 ${i + 1} / ${total}`;

      frag.appendChild(node);
    });

    track.appendChild(frag);
  }

  // Attach viewer-container events once
  function setupViewerFrame() {
    if (frameInit) return;
    const vw = document.getElementById('shorts-viewer');
    if (!vw) return;
    document.getElementById('exit-shorts')?.addEventListener('click', closeViewer);
    vw.addEventListener('touchstart', handleTouchStart, { passive: true });
    vw.addEventListener('touchmove', handleTouchMove, { passive: false });
    vw.addEventListener('touchend', handleTouchEnd);
    vw.addEventListener('mousedown', handleMouseDown);
    vw.addEventListener('mouseup', handleMouseUp);
    vw.addEventListener('wheel', handleWheel, { passive: false });
    document.addEventListener('keydown', handleKeyDown);
    frameInit = true;
  }

  function updatePanelPositions() {
    const ps = document.querySelectorAll('.tool-panel');
    ps.forEach((p, i) => {
      p.classList.remove('panel-visible', 'panel-above', 'panel-below');
      if (i === viewerState.pos) p.classList.add('panel-visible');
      else if (i < viewerState.pos) p.classList.add('panel-above');
      else p.classList.add('panel-below');
    });
    const ctr = ps[viewerState.pos]?.querySelector('.panel-counter');
    if (ctr) ctr.textContent = `🔀 ${viewerState.pos + 1} / ${ps.length}`;
  }

  function handleTouchStart(e: TouchEvent) { viewerState.drag0 = e.touches[0].clientY; viewerState.dragging = true; }
  function handleTouchMove(e: TouchEvent) { if (viewerState.dragging && viewerState.active) e.preventDefault(); }
  function handleTouchEnd(e: TouchEvent) {
    if (!viewerState.dragging || !viewerState.active) return;
    const d = viewerState.drag0 - e.changedTouches[0].clientY;
    if (Math.abs(d) > SWIPE_MIN) d > 0 ? advancePanel() : retreatPanel();
    viewerState.dragging = false;
  }
  function handleMouseDown(e: MouseEvent) {
    const el = e.target as HTMLElement;
    if (el.closest('.panel-action') || el.closest('.navigate-link') || el.closest('.exit-control')) return;
    viewerState.drag0 = e.clientY; viewerState.dragging = true;
  }
  function handleMouseUp(e: MouseEvent) {
    if (!viewerState.dragging || !viewerState.active) return;
    const d = viewerState.drag0 - e.clientY;
    if (Math.abs(d) > SWIPE_MIN) d > 0 ? advancePanel() : retreatPanel();
    viewerState.dragging = false;
  }
  function handleWheel(e: WheelEvent) {
    if (!viewerState.active) return;
    e.preventDefault();
    e.deltaY > 0 ? advancePanel() : retreatPanel();
  }

  function handleKeyDown(e: KeyboardEvent) {
    if (!viewerState.active) return;
    if (e.key === 'Tab') {
      const vw = document.getElementById('shorts-viewer');
      if (!vw) return;
      const all = vw.querySelectorAll<HTMLElement>(
        'button, a[href], input, [tabindex]:not([tabindex="-1"])'
      );
      const vis = vw.querySelector('.panel-visible');
      const foc = vis
        ? Array.from(all).filter(el => vis.contains(el) || el.id === 'exit-shorts')
        : Array.from(all);
      if (!foc.length) return;
      if (e.shiftKey && document.activeElement === foc[0]) {
        e.preventDefault(); foc[foc.length - 1].focus();
      } else if (!e.shiftKey && document.activeElement === foc[foc.length - 1]) {
        e.preventDefault(); foc[0].focus();
      }
      return;
    }
    const km: Record<string, () => void> = {
      ArrowDown:  () => { e.preventDefault(); advancePanel(); },
      ArrowRight: () => { e.preventDefault(); advancePanel(); },
      ArrowUp:    () => { e.preventDefault(); retreatPanel(); },
      ArrowLeft:  () => { e.preventDefault(); retreatPanel(); },
      Escape:     () => { e.preventDefault(); closeViewer(); },
    };
    km[e.key]?.();
  }

  function advancePanel() {
    const n = document.querySelectorAll('.tool-panel').length;
    viewerState.pos = (viewerState.pos + 1) % n; updatePanelPositions();
  }
  function retreatPanel() {
    const n = document.querySelectorAll('.tool-panel').length;
    viewerState.pos = (viewerState.pos - 1 + n) % n; updatePanelPositions();
  }

  function closeViewer() {
    const vw = document.getElementById('shorts-viewer');
    if (vw) {
      vw.classList.add('viewer-hidden');
      viewerState.active = false;
      document.body.style.overflow = '';
      previousFocus?.focus();
    }
  }

  async function toggleFavorite(e: Event) {
    const btn = e.currentTarget as HTMLElement;
    const toolId = btn.getAttribute('data-tool');
    if (!toolId) return;

    const isCurrentlyFavorited = btn.classList.contains('favorited');
    if (isCurrentlyFavorited) {
      const toolTitle = btn.getAttribute('data-tool-title') || 'this tool';
      const shouldRemove = await confirmFavoriteRemoval(toolTitle);
      if (!shouldRemove) return;
    }

    const isNowFavorited = toggleToolFavorite(toolId);
    btn.classList.toggle('favorited', isNowFavorited);
    btn.setAttribute('aria-label', `${isNowFavorited ? 'Remove from' : 'Add to'} favorites`);
    const svgEl = btn.querySelector('svg');
    if (svgEl) {
      svgEl.style.animation = 'heartbeat 0.35s ease';
      setTimeout(() => { svgEl.style.animation = ''; }, 350);
    }
  }

  function sharePanel(e: Event) {
    const btn = e.currentTarget as HTMLElement;
    const title = btn.getAttribute('data-tool-title');
    const pageUrl = window.location.origin + window.location.pathname;
    if (navigator.share) {
      navigator.share({
        title: title || 'Tiny Tool Town',
        text: title
          ? `Check out "${title}" on Tiny Tool Town! 🏘️`
          : 'Check out this tool on Tiny Tool Town! 🏘️',
        url: pageUrl,
      }).catch(() => {});
    } else {
      navigator.clipboard.writeText(pageUrl).then(() => {
        const lbl = btn.querySelector('.action-text');
        if (lbl) {
          const orig = lbl.textContent;
          lbl.textContent = 'Copied!';
          setTimeout(() => { lbl.textContent = orig; }, 2000);
        }
      });
    }
  }

  function loadFavoriteStates() {
    document.querySelectorAll<HTMLElement>('.favorite-action[data-tool]').forEach(btn => {
      const toolId = btn.dataset.tool;
      if (!toolId) return;
      const favorited = isFavorited(toolId);
      btn.classList.toggle('favorited', favorited);
      btn.setAttribute('aria-label', `${favorited ? 'Remove from' : 'Add to'} favorites`);
    });
  }

  function shufflePanels() {
    const track = document.querySelector('.viewer-track');
    if (!track) return;
    const ps = Array.from(track.querySelectorAll('.tool-panel'));
    for (let i = ps.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      track.appendChild(ps[j]);
      ps[j] = ps[i];
    }
  }

  (window as any).launchShortsViewer = function () {
    setupViewerFrame();
    buildPanels();
    const vw = document.getElementById('shorts-viewer');
    if (!vw) return;
    previousFocus = document.activeElement as HTMLElement;
    vw.classList.remove('viewer-hidden');
    viewerState.active = true;
    viewerState.pos = 0;
    document.body.style.overflow = 'hidden';
    shufflePanels();
    updatePanelPositions();
    loadFavoriteStates();
    document.getElementById('exit-shorts')?.focus();
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupViewerFrame);
  } else {
    setupViewerFrame();
  }

  // Keep favorites in sync when toggled from ToolCard or detail page
  window.addEventListener(FAVORITES_CHANGED_EVENT, loadFavoriteStates);

  // Fetch GitHub star counts once, when viewer first becomes visible
  const starCache = new Map<string, string>();
  function fetchStars() {
    document.querySelectorAll('.star-action[data-repo]').forEach(async el => {
      const repo = (el as HTMLElement).dataset.repo!;
      const lbl  = el.querySelector('.star-count-text');
      if (!lbl) return;
      if (starCache.has(repo)) { lbl.textContent = starCache.get(repo)!; return; }
      try {
        const res = await fetch(`https://api.github.com/repos/${repo}`);
        if (!res.ok) return;
        const data = await res.json();
        const cnt = data.stargazers_count as number;
        const text = '⭐ ' + (cnt >= 1000
          ? (cnt / 1000).toFixed(cnt >= 10000 ? 0 : 1) + 'k'
          : String(cnt));
        starCache.set(repo, text);
        lbl.textContent = text;
      } catch { /* network error — keep default label */ }
    });
  }
  const starObserver = new MutationObserver(() => {
    const vw = document.getElementById('shorts-viewer');
    if (vw && !vw.classList.contains('viewer-hidden')) {
      fetchStars();
      starObserver.disconnect();
    }
  });
  const vel = document.getElementById('shorts-viewer');
  if (vel) starObserver.observe(vel, { attributes: true, attributeFilter: ['class'] });
</script>


<style>
  #shorts-viewer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #000;
    overflow: hidden;
  }

  #shorts-viewer.viewer-hidden {
    display: none;
  }

  .exit-control {
    position: fixed;
    top: 1.25rem;
    left: 1.25rem;
    z-index: 10001;
    background: rgba(0, 0, 0, 0.65);
    border: none;
    color: #fff;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    display: grid;
    place-items: center;
    cursor: pointer;
    backdrop-filter: blur(12px);
    font-size: 1.375rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .exit-control:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.1);
  }

  .viewer-track {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .tool-panel {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateY(100%);
  }

  .tool-panel.panel-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }
  
  .tool-panel.panel-above {
    transform: translateY(-100%);
  }
  
  .tool-panel.panel-below {
    transform: translateY(100%);
  }

  .panel-bg {
    position: absolute;
    inset: 0;
  }

  .bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.45);
  }

  .bg-gradient {
    width: 100%;
    height: 100%;
  }

  .bg-dim {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, 
      rgba(0, 0, 0, 0.28) 0%, 
      rgba(0, 0, 0, 0.72) 100%);
  }

  .panel-content {
    position: absolute;
    bottom: 5.5rem;
    left: 0;
    right: 6rem;
    padding: 0 1.5rem;
    color: #fff;
    z-index: 10;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .tool-thumbnail {
    width: 3.875rem;
    height: 3.875rem;
    border-radius: 0.875rem;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(14px);
    display: grid;
    place-items: center;
    border: 2px solid rgba(255, 255, 255, 0.25);
  }

  .tool-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .thumb-placeholder {
    font-size: 2.125rem;
  }

  .tool-heading {
    font-size: 1.625rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
    text-shadow: 0 3px 12px rgba(0, 0, 0, 0.65);
  }

  .tool-description {
    font-size: 0.9375rem;
    line-height: 1.55;
    opacity: 0.96;
    margin: 0;
    text-shadow: 0 2px 7px rgba(0, 0, 0, 0.65);
  }

  .creator-info {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-top: 0.375rem;
  }

  .creator-avatar {
    width: 1.875rem;
    height: 1.875rem;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.35);
  }

  .creator-handle {
    font-size: 0.9375rem;
    font-weight: 600;
    text-shadow: 0 2px 7px rgba(0, 0, 0, 0.65);
  }

  .metadata-tags {
    display: flex;
    gap: 0.625rem;
    flex-wrap: wrap;
  }

  .metadata-tag {
    font-size: 0.8125rem;
    padding: 0.375rem 0.875rem;
    background: rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(14px);
    border-radius: 1.375rem;
    border: 1px solid rgba(255, 255, 255, 0.35);
    font-weight: 500;
  }

  .navigate-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.375rem;
    background: rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 1.75rem;
    color: #fff;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-top: 0.625rem;
    width: fit-content;
  }

  .navigate-link:hover {
    background: rgba(255, 255, 255, 0.35);
    transform: translateX(0.375rem);
  }

  .panel-actions {
    position: absolute;
    right: 1rem;
    bottom: 6.875rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    z-index: 10;
  }

  .panel-action {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.375rem;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(14px);
    border: none;
    color: #fff;
    padding: 0.75rem;
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }

  .panel-action:hover {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.12);
  }

  .action-text {
    font-size: 0.6875rem;
    font-weight: 600;
    text-shadow: 0 2px 7px rgba(0, 0, 0, 0.9);
  }

  .favorite-action.favorited svg {
    fill: #ff2d55;
    stroke: #ff2d55;
  }

  .star-action {
    text-decoration: none;
    color: inherit;
  }

  .star-action svg {
    fill: none;
  }

  .star-action:hover svg {
    fill: #ffd700;
    stroke: #ffd700;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.35); }
  }

  .panel-counter {
    position: absolute;
