---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ToolCard from '../../components/ToolCard.astro';
import TikTokView from '../../components/TikTokView.astro';
import ToolCounter from '../../components/ToolCounter.astro';
import { getCollection } from 'astro:content';
import { getGitHubRepo, fetchStarCounts } from '../../lib/github';

const allTools = await getCollection('tools');
const tools = allTools.sort((a, b) =>
  new Date(b.data.date_added).getTime() - new Date(a.data.date_added).getTime()
);

// Fetch GitHub star counts at build time
const repoMap = new Map<string, string>(); // slug -> owner/repo
for (const tool of tools) {
  const repo = getGitHubRepo(tool.data.github_url);
  if (repo) repoMap.set(tool.id, repo);
}
const starCounts = await fetchStarCounts([...repoMap.values()]);
const toolStars = new Map<string, number>();
for (const [slug, repo] of repoMap) {
  toolStars.set(slug, starCounts.get(repo) || 0);
}

// Count tag frequency and split into popular (3+) and rest
const tagCounts = new Map<string, number>();
tools.forEach(t => t.data.tags.forEach(tag => {
  const lower = tag.toLowerCase();
  tagCounts.set(lower, (tagCounts.get(lower) || 0) + 1);
}));
const popularTags = [...tagCounts.entries()]
  .filter(([, count]) => count >= 3)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);
const moreTags = [...tagCounts.entries()]
  .filter(([, count]) => count < 3)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([tag]) => tag);
---

<BaseLayout title="Browse Tools — Tiny Tool Town 🏘️" description="Explore all the tiny, delightful, open source tools in Tiny Tool Town.">
  <Header />

  <main id="main" class="container">
    <section class="browse-header" id="browse-header">
      <h1>Browse the Town 🏘️</h1>
      <ToolCounter count={tools.length} />
    </section>

    <!-- Search & Filter -->
    <div class="filter-bar">
      <div class="search-box">
        <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <label for="search" class="visually-hidden">Search tools</label>
        <input
          type="text"
          id="search"
          placeholder="Search tools..."
          class="search-input"
          autocomplete="off"
        />
      </div>
      <div class="sort-bar" role="group" aria-label="Sort tools">
        <span class="sort-label">Sort by</span>
        <button class="sort-btn active" data-sort="newest" aria-pressed="true">Newest</button>
        <button class="sort-btn" data-sort="oldest" aria-pressed="false">Oldest</button>
        <button class="sort-btn" data-sort="stars" aria-pressed="false">⭐ Stars</button>
        <button class="sort-btn favorites-only-btn" id="favorites-only-btn" aria-pressed="false">❤ Favorites only</button>
      </div>
      <div class="tags-filter" id="tags-filter">
        <button class="tag-btn active" data-tag="all">All</button>
        {popularTags.map(tag => (
          <button class="tag-btn" data-tag={tag}>{tag} <span class="tag-count">{tagCounts.get(tag)}</span></button>
        ))}
        {moreTags.length > 0 && (
          <button class="tag-btn more-tags-toggle" id="more-tags-toggle">More ▾</button>
        )}
        <div class="more-tags" id="more-tags" style="display: none;">
          {moreTags.map(tag => (
            <button class="tag-btn" data-tag={tag}>{tag}</button>
          ))}
        </div>
      </div>
    </div>

    <!-- Tool Grid -->
    <div class="tool-grid" id="tool-grid">
      {tools.map(tool => (
        <div class="tool-item"
          data-tool={tool.id.replace(/\.md$/, '')}
          data-name={tool.data.name.toLowerCase()}
          data-tagline={tool.data.tagline.toLowerCase()}
          data-tags={tool.data.tags.map(t => t.toLowerCase()).join(',')}
          data-author={tool.data.author.toLowerCase()}
          data-date-added={tool.data.date_added}
          data-stars={toolStars.get(tool.id) || 0}
          data-repo={repoMap.get(tool.id) || ''}
          data-favorited="false"
        >
          <ToolCard
            name={tool.data.name}
            slug={tool.id.replace(/\.md$/, '')}
            tagline={tool.data.tagline}
            author={tool.data.author}
            author_github={tool.data.author_github}
            tags={tool.data.tags}
            language={tool.data.language}
            featured={tool.data.featured}
            thumbnail={tool.data.thumbnail}
            github_url={tool.data.github_url}
            stars={toolStars.get(tool.id) ?? undefined}
          />
        </div>
      ))}
    </div>

    <div id="no-results" class="no-results" style="display: none;" aria-live="polite" aria-atomic="true">
      <p>🔍 No tools found. Try a different search?</p>
    </div>
  </main>

  <!-- Floating button to launch Shorts mode -->
  <button id="launch-vertical-view-tools" class="floating-shorts-btn" aria-label="Open shorts view">
    📱 Shorts
  </button>

  <TikTokView tools={tools} />

  <Footer />
</BaseLayout>

<script>
  import { FAVORITES_CHANGED_EVENT, readFavorites } from '../../lib/favorites';

  const search = document.getElementById('search') as HTMLInputElement;
  const grid = document.getElementById('tool-grid')!;
  const items = grid.querySelectorAll('.tool-item');
  const favoritesOnlyBtn = document.getElementById('favorites-only-btn') as HTMLButtonElement | null;
  const tagButtons = document.querySelectorAll('.tag-btn:not(.more-tags-toggle)');
  const noResults = document.getElementById('no-results')!;
  const moreToggle = document.getElementById('more-tags-toggle');
  const moreTags = document.getElementById('more-tags');

  const subtitle = document.getElementById('browse-subtitle');
  const counterNumber = document.querySelector<HTMLElement>('#browse-header .counter-number');
  const counterLabel = document.querySelector<HTMLElement>('#browse-header .counter-label');
  const totalCount = items.length;

  let activeTag = 'all';
  let activeSort = 'newest';
  let favoritesOnly = false;

  function syncFavoriteFlags(): void {
    const favorites = new Set(readFavorites());

    items.forEach(item => {
      const el = item as HTMLElement;
      const slug = el.dataset.tool || '';
      el.dataset.favorited = String(favorites.has(slug));
    });
  }

  function updateFavoritesButtonState(): void {
    if (!favoritesOnlyBtn) return;

    favoritesOnlyBtn.classList.toggle('active', favoritesOnly);
    favoritesOnlyBtn.setAttribute('aria-pressed', String(favoritesOnly));
  }

  function updateUrlState(): void {
    const url = new URL(window.location.href);
    if (activeSort === 'newest') {
      url.searchParams.delete('sort');
    } else {
      url.searchParams.set('sort', activeSort);
    }

    if (favoritesOnly) {
      url.searchParams.set('favorites', '1');
    } else {
      url.searchParams.delete('favorites');
    }

    history.replaceState(null, '', url.toString());
  }

  // "More ▾" expander
  if (moreToggle && moreTags) {
    moreToggle.addEventListener('click', () => {
      const visible = moreTags.style.display !== 'none';
      moreTags.style.display = visible ? 'none' : 'contents';
      moreToggle.textContent = visible ? 'More ▾' : 'Less ▴';
    });
  }

  function sortTools() {
    const itemsArray = Array.from(grid.querySelectorAll('.tool-item')) as HTMLElement[];
    itemsArray.sort((a, b) => {
      if (activeSort === 'newest') {
        return (b.dataset.dateAdded || '').localeCompare(a.dataset.dateAdded || '');
      } else if (activeSort === 'oldest') {
        return (a.dataset.dateAdded || '').localeCompare(b.dataset.dateAdded || '');
      } else if (activeSort === 'stars') {
        return (parseInt(b.dataset.stars || '0', 10)) - (parseInt(a.dataset.stars || '0', 10));
      }
      return 0;
    });
    for (const item of itemsArray) {
      grid.appendChild(item);
    }
  }

  function filterTools() {
    const query = search.value.toLowerCase().trim();
    let visible = 0;

    items.forEach(item => {
      const el = item as HTMLElement;
      const name = el.dataset.name || '';
      const tagline = el.dataset.tagline || '';
      const tags = (el.dataset.tags || '').toLowerCase();
      const author = el.dataset.author || '';
      const favorited = el.dataset.favorited === 'true';

      const matchesSearch = !query || name.includes(query) || tagline.includes(query) || tags.includes(query) || author.includes(query);
      const matchesTag = activeTag === 'all' || tags.split(',').includes(activeTag);
      const matchesFavorites = !favoritesOnly || favorited;

      if (matchesSearch && matchesTag && matchesFavorites) {
        el.style.display = '';
        visible++;
      } else {
        el.style.display = 'none';
      }
    });

    noResults.style.display = visible === 0 ? 'block' : 'none';
    if (subtitle) {
      subtitle.textContent = (visible === totalCount)
        ? `${totalCount} tiny tools and counting`
        : `Showing ${visible} of ${totalCount} tools`;
    }
    if (counterNumber && counterLabel) {
      // Prevent the ToolCounter animation from overwriting filtered counts
      counterNumber.dataset.animate = 'false';
      counterNumber.style.webkitTextFillColor = '';
      if (visible === totalCount) {
        counterNumber.textContent = String(totalCount);
        counterNumber.style.webkitTextFillColor = '';
        counterLabel.textContent = 'tiny tools and counting';
      } else {
        counterNumber.textContent = `${visible} of ${totalCount}`;
        counterLabel.textContent = 'tools shown';
      }
    }
  }

  // Sort button handler — exclude favorites-only button which has no data-sort
  document.querySelectorAll('.sort-btn:not(.favorites-only-btn)').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.sort-btn:not(.favorites-only-btn)').forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-pressed', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-pressed', 'true');
      activeSort = (btn as HTMLElement).dataset.sort || 'newest';
      sortTools();
      updateUrlState();
    });
  });

  favoritesOnlyBtn?.addEventListener('click', () => {
    favoritesOnly = !favoritesOnly;
    updateFavoritesButtonState();
    filterTools();
    updateUrlState();
  });

  // Pre-fill search from ?q= URL parameter, or activate tag from ?tag=
  const params = new URLSearchParams(window.location.search);
  const urlQ = params.get('q');
  const urlTag = params.get('tag');
  const urlSort = params.get('sort');
  const urlFavorites = params.get('favorites');

  // Apply sort from URL
  if (urlSort && ['newest', 'oldest', 'stars'].includes(urlSort)) {
    activeSort = urlSort;
    document.querySelectorAll('.sort-btn').forEach(b => {
      const isActive = (b as HTMLElement).dataset.sort === activeSort;
      b.classList.toggle('active', isActive);
      b.setAttribute('aria-pressed', String(isActive));
    });
    sortTools();
  }

  favoritesOnly = urlFavorites === '1' || urlFavorites === 'true';
  updateFavoritesButtonState();

  if (urlQ) {
    search.value = urlQ;
    filterTools();
  } else if (urlTag) {
    activeTag = urlTag.toLowerCase();
    // Activate the matching tag button (may be in the "more" section)
    if (moreTags && moreToggle) {
      const allBtns = document.querySelectorAll('.tag-btn[data-tag]');
      let found = false;
      allBtns.forEach(b => {
        if ((b as HTMLElement).dataset.tag === activeTag) {
          found = true;
          // If it's inside the hidden more-tags section, expand it
          if (b.closest('#more-tags')) {
            moreTags.style.display = 'contents';
            moreToggle.textContent = 'Less ▴';
          }
          document.querySelectorAll('.tag-btn').forEach(x => x.classList.remove('active'));
          b.classList.add('active');
        }
      });
    }
    filterTools();
  }

  search.addEventListener('input', filterTools);

  syncFavoriteFlags();
  filterTools();
  window.addEventListener(FAVORITES_CHANGED_EVENT, () => {
    syncFavoriteFlags();
    filterTools();
  });

  // Handle tag clicks (both popular and expanded)
  document.getElementById('tags-filter')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.tag-btn:not(.more-tags-toggle)') as HTMLElement;
    if (!btn || !btn.dataset.tag) return;
    document.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeTag = btn.dataset.tag;
    filterTools();
  });

  // --- Client-side lazy star refresh via IntersectionObserver + localStorage ---
  const STAR_CACHE_PREFIX = 'ttt_stars_';
  const STAR_TTL_MS = 60 * 60 * 1000; // 1 hour
  const MAX_FETCHES = 30;
  let fetchBudget = MAX_FETCHES;

  function getCachedStars(repo: string): number | null {
    try {
      const raw = localStorage.getItem(STAR_CACHE_PREFIX + repo);
      if (!raw) return null;
      const entry = JSON.parse(raw);
      if (entry === null || typeof entry !== 'object') {
        localStorage.removeItem(STAR_CACHE_PREFIX + repo);
        return null;
      }
      const ts = Number(entry.ts);
      const stars = Number(entry.stars);
      if (!Number.isFinite(ts) || !Number.isFinite(stars)) {
        localStorage.removeItem(STAR_CACHE_PREFIX + repo);
        return null;
      }
      if (Date.now() - ts > STAR_TTL_MS) {
        localStorage.removeItem(STAR_CACHE_PREFIX + repo);
        return null;
      }
      return stars;
    } catch { return null; }
  }

  function setCachedStars(repo: string, stars: number): void {
    try {
      localStorage.setItem(STAR_CACHE_PREFIX + repo, JSON.stringify({ stars, ts: Date.now() }));
    } catch { /* quota exceeded, ignore */ }
  }

  function updateCardStars(item: HTMLElement, stars: number): void {
    item.dataset.stars = String(stars);
    const countEl = item.querySelector('.card-stars-count');
    if (countEl) countEl.textContent = `⭐ ${stars.toLocaleString()}`;
  }

  async function refreshStars(item: HTMLElement): Promise<void> {
    const repo = item.dataset.repo;
    if (!repo) return;

    // Check localStorage first
    const cached = getCachedStars(repo);
    if (cached !== null) {
      updateCardStars(item, cached);
      return;
    }

    // Respect fetch budget
    if (fetchBudget <= 0) return;
    fetchBudget--;

    try {
      const controller = new AbortController();
      const timeout = setTimeout(() => controller.abort(), 5000);
      try {
        const res = await fetch(`https://api.github.com/repos/${repo}`, {
          headers: { 'Accept': 'application/vnd.github.v3+json' },
          signal: controller.signal,
        });
        if (!res.ok) return;
        const data = await res.json();
        const stars = data.stargazers_count || 0;
        setCachedStars(repo, stars);
        updateCardStars(item, stars);
      } finally {
        clearTimeout(timeout);
      }
    } catch { /* network error, keep build-time value */ }
  }

  // Observe tool cards as they enter the viewport
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          observer.unobserve(entry.target);
          refreshStars(entry.target as HTMLElement);
        }
      }
    }, { rootMargin: '200px' });

    items.forEach(item => observer.observe(item));
  }
</script>

<style>
  .browse-header {
    padding: 2.5rem 0 1.5rem;
  }

  .browse-header h1 {
    font-size: 2rem;
    font-weight: 900;
  }

  .browse-subtitle {
    color: var(--color-text);
    opacity: 0.7;
    margin-top: 0.25rem;
  }

  .filter-bar {
    margin-bottom: 2rem;
  }

  .search-box {
    position: relative;
    margin-bottom: 1rem;
  }

  .sort-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .sort-label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-right: 0.25rem;
  }

  .sort-btn {
    padding: 0.4rem 0.9rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 50px;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s;
  }

  .sort-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .sort-btn.active {
    background: var(--color-primary);
    color: var(--color-bg);
    border-color: var(--color-primary);
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.85rem 1rem 0.85rem 2.75rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 0.2s;
  }

  .search-input::placeholder {
    color: var(--color-text-muted);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-primary);
  }

  .tags-filter {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag-btn {
    padding: 0.4rem 0.9rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: 50px;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.2s;
  }

  .tag-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .tag-btn.active {
    background: var(--color-primary);
    color: var(--color-bg);
    border-color: var(--color-primary);
  }

  .tag-count {
    font-size: 0.7rem;
    opacity: 0.6;
    margin-left: 0.15rem;
  }

  .tag-btn.active .tag-count {
    opacity: 0.8;
  }

  .more-tags-toggle {
    border-style: dashed;
    font-style: italic;
  }

  .more-tags {
    display: contents;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .no-results {
    text-align: center;
    padding: 3rem;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  /* Floating Shorts Button */
  .floating-shorts-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
    background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
    color: #fff;
    border: none;
    padding: 0.875rem 1.5rem;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(255, 137, 6, 0.35);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .floating-shorts-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 12px 32px rgba(255, 137, 6, 0.5);
  }

  .floating-shorts-btn:active {
    transform: translateY(-1px) scale(1.02);
  }

  @media (max-width: 640px) {
    .floating-shorts-btn {
      bottom: 1.25rem;
      right: 1.25rem;
      padding: 0.75rem 1.25rem;
      font-size: 0.9rem;
    }
  }
</style>

<script>
  // Launch vertical shorts view when button is clicked
  const launchBtn = document.getElementById('launch-vertical-view-tools');
  if (launchBtn) {
    launchBtn.addEventListener('click', () => {
      if (typeof (window as any).launchShortsViewer === 'function') {
        (window as any).launchShortsViewer();
      }
    });
  }
</script>
